{
  "locals": {
    "router": {
      "name":"router",
      "backend": "pki-int-prod",
      "common_name": "router.rachuna.dev",
      "allowed_domains": [
        "router.rachuna.dev",
        "router"
      ],
      "alt_names": [
        "router.rachuna.dev",
        "router"
      ],
      "ip_sans": [
        "10.0.0.1",
        "10.1.0.1",
        "10.2.0.1",
        "10.3.0.1",
        "10.3.1.1",
        "10.3.2.1"
      ]
    }
  },
  "resource": {
    "vault_pki_secret_backend_role": {
      "router": {
        "backend": "${local.router.backend}",
        "name": "${local.router.name}",
        "ttl": "31536000",
        "max_ttl": "31536000",
        "allowed_domains": "${local.router.allowed_domains}",
        "allow_subdomains": true,
        "allow_bare_domains": true,
        "allow_ip_sans": true,
        "allow_localhost": false,
        "server_flag": true,
        "client_flag": false,
        "key_type": "rsa",
        "key_bits": 4096,
        "organization": ["RACHUNA.DEV"],
        "ou": ["RACHUNA.DEV PKI"],
        "country": ["PL"],
        "locality": ["Toruń"]
      }
    },
    "vault_pki_secret_backend_cert": {
      "router": {
        "backend": "${local.router.backend}",
        "name": "${local.router.name}",
        "common_name": "${local.router.common_name}",
        "alt_names": "${local.router.alt_names}",
        "ip_sans": "${local.router.ip_sans}",
        "ttl": "31536000",
        "auto_renew": true,
        "min_seconds_remaining": 604800
      }
    }
  }
}
