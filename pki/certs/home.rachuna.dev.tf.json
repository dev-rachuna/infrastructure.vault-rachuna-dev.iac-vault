{
  "locals": {
    "home": {
      "name":"home",
      "backend": "pki-int-prod",
      "common_name": "home.rachuna.dev",
      "allowed_domains": [
        "home.rachuna.dev",
        "home"
      ],
      "alt_names": [
        "home.rachuna.dev",
        "home"
      ],
      "ip_sans": [
        "10.0.0.4"
      ]
    }
  },
  "resource": {
    "vault_pki_secret_backend_role": {
      "home": {
        "backend": "${local.home.backend}",
        "name": "${local.home.name}",
        "ttl": "31536000",
        "max_ttl": "31536000",
        "allowed_domains": "${local.home.allowed_domains}",
        "allow_subdomains": true,
        "allow_bare_domains": true,
        "allow_ip_sans": true,
        "allow_localhost": false,
        "server_flag": true,
        "client_flag": false,
        "key_type": "rsa",
        "key_bits": 4096,
        "organization": ["RACHUNA.DEV"],
        "ou": ["RACHUNA.DEV PKI"],
        "country": ["PL"],
        "locality": ["Toruń"]
      }
    },
    "vault_pki_secret_backend_cert": {
      "home": {
        "depends_on": [
          "vault_pki_secret_backend_role.home"
        ],
        "backend": "${local.home.backend}",
        "name": "${local.home.name}",
        "common_name": "${local.home.common_name}",
        "alt_names": "${local.home.alt_names}",
        "ip_sans": "${local.home.ip_sans}",
        "ttl": "31536000",
        "auto_renew": true,
        "min_seconds_remaining": 604800
      }
    },
     "vault_kv_secret_v2": {
      "home": {
        "depends_on": [
          "vault_pki_secret_backend_cert.home"
        ],
        "mount": "dev.rachuna",
        "name": "infrastructure/vault-rachuna-dev/iac-vault/${local.home.common_name}",
        "data_json": "${jsonencode({ certificate = vault_pki_secret_backend_cert.home.certificate, private_key = vault_pki_secret_backend_cert.home.private_key, issuing_ca = vault_pki_secret_backend_cert.home.issuing_ca, ca_chain = vault_pki_secret_backend_cert.home.ca_chain, serial_number = vault_pki_secret_backend_cert.home.serial_number })}"
      }
    }
  }
}
