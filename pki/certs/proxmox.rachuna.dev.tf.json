{
  "locals": {
    "proxmox": {
      "name":"proxmox",
      "backend": "pki-int-prod",
      "common_name": "pve.rachuna.dev",
      "allowed_domains": [
        "pve.rachuna.dev",
        "pve-s1.rachuna.dev",
        "pve-s2.rachuna.dev",
        "pve-s3.rachuna.dev",
        "pve-s4.rachuna.dev",
        "pve",
        "pve-s1",
        "pve-s2",
        "pve-s3",
        "pve-s4"
      ],
      "alt_names": [
        "pve.rachuna.dev",
        "pve-s1.rachuna.dev",
        "pve-s2.rachuna.dev",
        "pve-s3.rachuna.dev",
        "pve-s4.rachuna.dev",
        "pve",
        "pve-s1",
        "pve-s2",
        "pve-s3",
        "pve-s4"
      ],
      "ip_sans": [
        "10.3.0.11",
        "10.3.0.12",
        "10.3.0.13",
        "10.3.0.14"
      ]
    }
  },
  "resource": {
    "vault_pki_secret_backend_role": {
      "proxmox": {
        "backend": "${local.proxmox.backend}",
        "name": "${local.proxmox.name}",
        "ttl": "31536000",
        "max_ttl": "31536000",
        "allowed_domains": "${local.proxmox.allowed_domains}",
        "allow_subdomains": true,
        "allow_bare_domains": true,
        "allow_ip_sans": true,
        "allow_localhost": false,
        "server_flag": true,
        "client_flag": false,
        "key_type": "rsa",
        "key_bits": 4096,
        "organization": ["RACHUNA.DEV"],
        "ou": ["RACHUNA.DEV PKI"],
        "country": ["PL"],
        "locality": ["Toruń"]
      }
    },
    "vault_pki_secret_backend_cert": {
      "proxmox": {
        "depends_on": [
          "vault_pki_secret_backend_role.proxmox"
        ],
        "backend": "${local.proxmox.backend}",
        "name": "${local.proxmox.name}",
        "common_name": "${local.proxmox.common_name}",
        "alt_names": "${local.proxmox.alt_names}",
        "ip_sans": "${local.proxmox.ip_sans}",
        "ttl": "31536000",
        "auto_renew": true,
        "min_seconds_remaining": 604800
      }
    },
     "vault_kv_secret_v2": {
      "proxmox": {
        "depends_on": [
          "vault_pki_secret_backend_cert.proxmox"
        ],
        "mount": "dev.rachuna",
        "name": "infrastructure/vault-rachuna-dev/iac-vault/${local.proxmox.common_name}",
        "data_json": "${jsonencode({ certificate = vault_pki_secret_backend_cert.proxmox.certificate, private_key = vault_pki_secret_backend_cert.proxmox.private_key, issuing_ca = vault_pki_secret_backend_cert.proxmox.issuing_ca, ca_chain = vault_pki_secret_backend_cert.proxmox.ca_chain, serial_number = vault_pki_secret_backend_cert.proxmox.serial_number })}"
      }
    }
  }
}
